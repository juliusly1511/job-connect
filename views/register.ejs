<%- include('partials/header', { title: 'Sign Up' }) %>

<div class="form-card">
  <h1>Create account</h1>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <form action="/auth/register" method="POST">
    <div class="form-group">
      <label>I am a...</label>
      <div class="role-toggle">
        <label>
          <input type="radio" name="role" value="seeker" <%= form.role !== 'employer' ? 'checked' : '' %> />
          <span>Job Seeker</span>
        </label>
        <label>
          <input type="radio" name="role" value="employer" <%= form.role === 'employer' ? 'checked' : '' %> />
          <span>Employer</span>
        </label>
      </div>
    </div>
    <div class="form-group">
      <label>Full name</label>
      <input name="name" value="<%= form.name || '' %>" required />
    </div>
    <div class="form-group">
      <label>Email</label>
      <input name="email" type="email" value="<%= form.email || '' %>" required />
    </div>
    <div class="form-group">
      <label>Password (min 6 chars)</label>
      <input name="password" type="password" minlength="6" required />
    </div>
    <div class="form-group">
      <label>Company name (employers only — optional)</label>
      <input name="company" value="<%= form.company || '' %>" />
    </div>
    <button class="btn" type="submit" style="width:100%;">Create account</button>
  </form>
  <p style="text-align:center;margin-top:16px;font-size:14px;">
    Already have an account? <a href="/auth/login">Sign in</a>
  </p>
</div>

<%- include('partials/footer') %>
