<%- include('partials/header', { title: 'JobBoard — Find your next job' }) %>

<section class="hero">
  <h1>Find your next job</h1>
  <p>Search thousands of opportunities from top companies.</p>
  <form class="search" action="/" method="GET">
    <input type="text" name="q" placeholder="Job title, keywords, or company" value="<%= query.q %>" />
    <input type="text" name="location" placeholder="Location" value="<%= query.location %>" />
    <select name="category">
      <option value="">All categories</option>
      <% categories.forEach(c => { %>
        <option value="<%= c %>" <%= query.category === c ? 'selected' : '' %>><%= c %></option>
      <% }) %>
    </select>
    <button class="btn btn-accent" type="submit">Search</button>
  </form>
</section>

<div class="container">
  <h2 style="margin-top:0;"><%= jobs.length %> job<%= jobs.length === 1 ? '' : 's' %> found</h2>

  <% if (jobs.length === 0) { %>
    <div class="empty">
      <p>No jobs match your search. Try different keywords.</p>
    </div>
  <% } else { %>
    <div class="grid">
      <% jobs.forEach(job => { %>
        <article class="job-card">
          <h3><a href="/jobs/<%= job._id %>"><%= job.title %></a></h3>
          <div class="company"><%= job.company %> &middot; <%= job.location %></div>
          <div class="job-meta">
            <span class="tag"><%= job.category %></span>
            <span class="tag tag-muted"><%= job.type %></span>
            <% if (job.salary) { %><span class="tag tag-muted"><%= job.salary %></span><% } %>
          </div>
          <div class="posted">Posted <%= new Date(job.createdAt).toLocaleDateString() %></div>
        </article>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
